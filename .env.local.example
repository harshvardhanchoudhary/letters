# ── Supabase ──────────────────────────────────────────────────────────────────
# Copy these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Access control ─────────────────────────────────────────────────────────────
# Only these two emails can ever sign in. Nobody else gets through.
# Add her email before you show her — she'll use it to sign up.
ALLOWED_EMAIL_1=your_email@example.com
ALLOWED_EMAIL_2=her_email@example.com

# ── Import only (never goes to Vercel) ─────────────────────────────────────────
# Used only by import-letters.js — never commit this value, never add to Vercel
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Display names ──────────────────────────────────────────────────────────────
# These are used in letters and greetings. Set them before she joins
# so her name shows correctly from the start.
DISPLAY_NAME_1=Your Name
DISPLAY_NAME_2=Her Name
